go athena

init inf=Lab04_8.str

# Implantation (Monte Carlo)
cluster i.phosphor min.cluster=1e17 max.cluster=1.5e19 clust.fact=1.4 
disloc.loop i.phosphor min.loop.co=1e17 max.loop.co=1e18 
#
implant phosphor dose=1.0e14 energy=200 monte mcseed=2 n.ion=10000 smooth=0.25 tilt=0 rotation=0 crystal unit.damage dam.factor=1

Struct outf= Lab06_3.str

extract name="Nd" 2d.max.conc impurity="Active Boron" material="Silicon" y.min=0 x.max=10 y.max=10 x.min=0 x.max=50

extract name="Nd X position" x.pos
extract name="Nd Y position" y.pos

extract name="Vertical_Junction_Depth (after predopostion)" xj silicon mat.occno=1 x.val=25 junc.occno=1

tonyplot  Lab06_3.str

quit