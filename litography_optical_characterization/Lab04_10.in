go athena

init inf=Lab03_1.str

# Dry Etch
rate.etch machine=RIE_Machine_Oxide_SF6 oxide u.m rie isotropic=0.1 dir=0.2 chem=0.2 div=0.1

# Machine Etch
etch machine=RIE_Machine_Oxide_SF6 time=2 minutes 

# Strip PR
strip

struct outf=Lab04_RIE_Machine_Oxide_SF6.str

tonyplot Lab03_1.str Lab04_RIE_Machine_Oxide_SF6.str

quit